{
  "expo": {
    "name": "EgoCapture",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.locara.egocentric.capture",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera access to record egocentric videos.",
          "microphonePermission": "Allow microphone access to record video audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow location access to attach GPS metadata to recordings."
        }
      ],
      "expo-video"
    ],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:8000",
      "maxRecordingDurationSeconds": 60
    }
  }
}
