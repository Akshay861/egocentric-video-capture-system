# Mobile app only — no AWS credentials here.
#
# Copy to .env for local Expo Go development:
#   cp .env.example .env
#
# The app picks the API URL automatically:
#   • Android emulator  → http://10.0.2.2:8000
#   • Physical phone    → EXPO_PUBLIC_DEVICE_API_BASE_URL (your PC LAN IP)
#
# Find your PC IP: hostname -I | awk '{print $1}'

EXPO_PUBLIC_DEVICE_API_BASE_URL=http://192.168.1.100:8000
EXPO_PUBLIC_MAX_RECORDING_DURATION_SECONDS=60
