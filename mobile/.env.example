# Mobile app only — no AWS credentials here.
#
# Option 1 (recommended for local dev): set values in app.json under expo.extra
# Option 2: copy this file to .env and fill in values (Expo loads EXPO_PUBLIC_* vars)
#
# Android emulator → backend on host machine:
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
#
# Physical device on same Wi‑Fi → use your computer's LAN IP, e.g.:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8000

EXPO_PUBLIC_MAX_RECORDING_DURATION_SECONDS=60
