# Backend only — AWS and server settings. Never put these in the mobile app.
#
# Copy to backend/.env and fill in real values:
#   cp .env.example .env

# AWS region where your S3 bucket lives
AWS_REGION=ap-south-1

# S3 bucket for egocentric video uploads
S3_BUCKET_NAME=locara-egocentric-videos-dev

# IAM credentials for the presigned URL generator (use IAM role in production)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Presigned PUT URL lifetime in seconds (900 = 15 minutes)
PRESIGN_TTL_SECONDS=900

# Local API server bind address
HOST=0.0.0.0
PORT=8000
